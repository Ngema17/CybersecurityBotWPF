<Window x:Class="CybersecurityBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#12192D">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1C2337" BorderBrush="#2A3348" BorderThickness="0,0,0,2">
            <StackPanel Margin="20,15,0,0">
                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="[ SAFE • SMART • SECURE ]" 
                           FontSize="14" 
                           FontWeight="Bold" 
                           Foreground="#64C864"
                           Margin="0,5,0,0"/>
                <TextBlock x:Name="StatusText" 
                           Text="● Ready" 
                           FontSize="11" 
                           Foreground="#64C864"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="1" Background="#1E2537">
            <ScrollViewer x:Name="ChatScrollViewer" 
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ChatPanel" Margin="15" Orientation="Vertical"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#1C2337" BorderBrush="#2A3348" BorderThickness="0,2,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox" 
                         Grid.Column="0"
                         Height="40"
                         FontSize="14"
                         Background="#28334A"
                         Foreground="White"
                         BorderBrush="#3D4A6B"
                         BorderThickness="1"
                         Padding="10,0,10,0"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="SEND"
                        Width="70"
                        Height="40"
                        Margin="10,0,10,0"
                        Background="#3278C8"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="SendButton_Click"/>

                <Button x:Name="ExitButton" 
                        Grid.Column="2"
                        Content="EXIT"
                        Width="70"
                        Height="40"
                        Background="#C84646"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="ExitButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>